{
  "manifest_version": 3,
  "name": "Meridian Clipper",
  "version": "1.13",
  "description": "Save full article text to Meridian",
  "permissions": [
    "cookies",
    "tabs",
    "storage",
    "activeTab",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://meridianreader.com/*",
    "https://www.bloomberg.com/*",
    "https://www.economist.com/*",
    "https://www.ft.com/*",
    "https://ig.ft.com/*",
    "https://www.foreignaffairs.com/*",
    "https://professional-monetary-policy-radar.ft.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.bloomberg.com/*",
        "https://www.economist.com/*",
        "https://www.ft.com/*",
        "https://www.foreignaffairs.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Meridian"
  }
}